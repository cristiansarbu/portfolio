---
import { Image } from 'astro:assets';
import spainskillsMe from '../assets/img/spainskills_me.png';
import type { useTranslations } from '../i18n/utils';

interface Props {
  t: ReturnType<typeof useTranslations>;
}
const { t } = Astro.props;
---

<section id="about" class="reveal px-6 max-w-3xl mx-auto py-24">
  <h2 class="text-3xl font-bold text-white mb-6">{t('about.title')}</h2>
  <div class="flex flex-col gap-4 mb-10 max-w-2xl">
    <p class="text-zinc-300 text-sm leading-relaxed">{t('about.lead')}</p>
    <p class="text-zinc-300 text-sm leading-relaxed">{t('about.p2')}</p>
  </div>
  <Image
    src={spainskillsMe}
    alt="Angelo at SpainSkills 2026"
    width={1915}
    height={1078}
    loading="lazy"
    draggable={false}
    class="w-full h-auto rounded-xl object-cover object-top shadow-2xl shadow-zinc-950/60 ring-1 ring-white/[0.06]"
  />
</section>
