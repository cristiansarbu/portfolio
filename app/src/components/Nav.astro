---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import logo from '../assets/img/logo_transparent.png';
import type { useTranslations, Locale } from '../i18n/utils';

interface Props {
  t: ReturnType<typeof useTranslations>;
  lang: Locale;
}
const { t, lang } = Astro.props;

const locales: { code: Locale; label: string }[] = [
  { code: 'es', label: 'ES' },
  { code: 'en', label: 'EN' },
  { code: 'de', label: 'DE' },
];

function localePath(code: Locale) {
  return code === 'es' ? '/' : `/${code}/`;
}

const homePath = localePath(lang);

const navLinks = [
  { href: '#experience', label: t('nav.experience') },
  { href: '#education',  label: t('nav.education')  },
  { href: '#projects',   label: t('nav.projects')   },
  { href: '#stack',      label: t('nav.stack')       },
  { href: '#contact',    label: t('nav.contact')     },
];
---

<header data-home-path={homePath} class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-zinc-950/80 border-b border-zinc-800/50 shadow-lg shadow-zinc-950/50">
  <div class="mx-auto px-4 max-w-3xl flex items-center justify-between py-4">

    <Image src={logo} alt="ACS." class="h-8 w-auto flex-shrink-0" draggable={false} />

    <!-- Desktop nav -->
    <nav class="hidden sm:flex items-center gap-6 text-sm text-zinc-400" aria-label="Primary navigation">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="nav-link hover:text-white transition-colors">{label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <!-- Language switcher dropdown -->
      <div class="relative" id="lang-switcher">
        <button
          id="lang-btn"
          type="button"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-label="Select language"
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-zinc-800/70 border border-zinc-700/50 text-white text-sm font-semibold hover:bg-zinc-700/70 transition-colors cursor-pointer"
        >
          <Icon name="heroicons:language" class="w-4 h-4 text-zinc-300" aria-hidden="true" />
          <span id="lang-label">{locales.find(l => l.code === lang)?.label}</span>
          <Icon name="heroicons:chevron-down" id="lang-chevron" class="w-3 h-3 text-zinc-400 transition-transform duration-200" aria-hidden="true" />
        </button>

        <ul
          id="lang-menu"
          role="listbox"
          aria-label="Language options"
          class="absolute right-0 mt-1.5 w-24 bg-zinc-900 border border-zinc-700/50 rounded-lg shadow-xl overflow-hidden hidden"
        >
          {locales.map(({ code, label }) => (
            <li role="option" aria-selected={lang === code}>
              <a
                href={localePath(code)}
                class={`block px-4 py-2 text-sm font-medium transition-colors ${
                  lang === code
                    ? 'text-white bg-zinc-700/60'
                    : 'text-zinc-400 hover:text-white hover:bg-zinc-800/60'
                }`}
                aria-current={lang === code ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Hamburger (mobile only) -->
      <button
        id="nav-toggle"
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="sm:hidden p-1.5 text-zinc-400 hover:text-white transition-colors"
      >
        <Icon name="heroicons:bars-3" id="icon-menu" class="w-5 h-5" aria-hidden="true" />
        <Icon name="heroicons:x-mark" id="icon-close" class="w-5 h-5 hidden" aria-hidden="true" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden sm:hidden border-t border-zinc-800/50"
    aria-label="Mobile navigation"
  >
    <ul class="flex flex-col px-4 py-2">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="block py-3 px-2 text-sm text-zinc-400 rounded hover:bg-zinc-800/50 hover:text-white transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const homePath = document.querySelector('header')!.dataset.homePath as string;

  // Language dropdown
  const langBtn     = document.getElementById('lang-btn')     as HTMLButtonElement;
  const langMenu    = document.getElementById('lang-menu')    as HTMLUListElement;
  const langChevron = document.querySelector<SVGSVGElement>('#lang-chevron')!;

  function openLang() {
    langMenu.classList.remove('hidden');
    langChevron.style.transform = 'rotate(180deg)';
    langBtn.setAttribute('aria-expanded', 'true');
  }
  function closeLang() {
    langMenu.classList.add('hidden');
    langChevron.style.transform = '';
    langBtn.setAttribute('aria-expanded', 'false');
  }

  langBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    langMenu.classList.contains('hidden') ? openLang() : closeLang();
  });
  document.addEventListener('click', () => closeLang());
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLang(); });

  const toggle    = document.getElementById('nav-toggle')  as HTMLButtonElement;
  const menu      = document.getElementById('mobile-menu') as HTMLElement;
  const iconMenu  = document.querySelector<SVGSVGElement>('#icon-menu')!;
  const iconClose = document.querySelector<SVGSVGElement>('#icon-close')!;

  function openMenu() {
    menu.classList.remove('hidden');
    iconMenu.classList.add('hidden');
    iconClose.classList.remove('hidden');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close navigation menu');
  }

  function closeMenu() {
    menu.classList.add('hidden');
    iconMenu.classList.remove('hidden');
    iconClose.classList.add('hidden');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open navigation menu');
  }

  toggle.addEventListener('click', () => {
    menu.classList.contains('hidden') ? openMenu() : closeMenu();
  });

  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', (e) => {
      e.preventDefault();
      const id = anchor.getAttribute('href')!.slice(1);
      const target = id ? document.getElementById(id) : null;

      if (!target) {
        window.location.href = `${homePath}#${id}`;
        return;
      }

      target.scrollIntoView({ behavior: 'smooth' });
      history.replaceState(null, '', location.pathname);

      if (!menu.classList.contains('hidden')) closeMenu();
    });
  });
</script>
