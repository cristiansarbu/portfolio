---
import { Icon } from 'astro-icon/components';
import type { useTranslations } from '../i18n/utils';

interface Props {
  t: ReturnType<typeof useTranslations>;
}
const { t } = Astro.props;

interface Tech {
  name: string;
  icon?: string;
  color?: string;
}

const groups: { label: string; items: Tech[] }[] = [
  {
    label: t('stack.frontend'),
    items: [
      { name: 'HTML',       icon: 'simple-icons:html5',       color: '#E34F26' },
      { name: 'CSS',        icon: 'simple-icons:css3',        color: '#1572B6' },
      { name: 'JavaScript', icon: 'simple-icons:javascript',  color: '#F7DF1E' },
      { name: 'TypeScript', icon: 'simple-icons:typescript',  color: '#3178C6' },
      { name: 'Angular',    icon: 'simple-icons:angular',     color: '#DD0031' },
      { name: 'Bootstrap',  icon: 'simple-icons:bootstrap',   color: '#7952B3' },
      { name: 'Figma',      icon: 'simple-icons:figma',       color: '#F24E1E' },
    ],
  },
  {
    label: t('stack.backend'),
    items: [
      { name: 'PHP',        icon: 'simple-icons:php',        color: '#777BB4' },
      { name: 'Laravel',    icon: 'simple-icons:laravel',    color: '#FF2D20' },
      { name: 'Node.js',    icon: 'simple-icons:nodedotjs',  color: '#339933' },
      { name: 'Express',    icon: 'simple-icons:express',    color: '#ffffff' },
      { name: 'PostgreSQL', icon: 'simple-icons:postgresql', color: '#4169E1' },
      { name: 'MySQL',      icon: 'simple-icons:mysql',      color: '#4479A1' },
    ],
  },
  {
    label: t('stack.cloud'),
    items: [
      { name: 'AWS',            icon: 'simple-icons:amazonwebservices', color: '#FF9900' },
      { name: 'Docker',         icon: 'simple-icons:docker',            color: '#2496ED' },
      { name: 'Docker Compose', icon: 'simple-icons:docker',            color: '#2496ED' },
      { name: 'Nginx',   icon: 'simple-icons:nginx',  color: '#009639' },
      { name: 'Apache', icon: 'simple-icons:apache', color: '#D22128' },
    ],
  },
  {
    label: t('stack.tools'),
    items: [
      { name: 'Git',     icon: 'simple-icons:git',              color: '#F05032' },
      { name: 'GitHub',  icon: 'simple-icons:github',           color: '#ffffff' },
      { name: 'Jira',    icon: 'simple-icons:jira',             color: '#0052CC' },
      { name: 'Bash',    icon: 'simple-icons:gnubash',          color: '#4EAA25' },
      { name: 'Claude',    icon: 'simple-icons:anthropic', color: '#D97757' },
      { name: 'JetBrains', icon: 'simple-icons:jetbrains',  color: '#FF318C' },
    ],
  },
  {
    label: t('stack.learning'),
    items: [
      { name: 'Python',       icon: 'simple-icons:python',      color: '#3776AB' },
      { name: 'Tailwind CSS', icon: 'simple-icons:tailwindcss', color: '#06B6D4' },
      { name: 'vLLM' },
      { name: 'Astro',        icon: 'simple-icons:astro',       color: '#FF5D01' },
      { name: 'Azure',      icon: 'simple-icons:microsoftazure', color: '#0078D4' },
      { name: 'NestJS',     icon: 'simple-icons:nestjs',         color: '#E0234E' },
      { name: 'Kubernetes', icon: 'simple-icons:kubernetes',     color: '#326CE5' },
    ],
  },
];
---

<section id="stack" class="reveal px-6 max-w-3xl mx-auto py-24">
  <h2 class="text-3xl font-bold text-white mb-12">{t('stack.title')}</h2>

  <div class="grid gap-6 sm:grid-cols-2">
    {groups.map((group) => (
      <div class="rounded-2xl border border-zinc-700/50 bg-zinc-900/60 p-6">
        <h3 class="text-xl font-bold text-center text-white mb-6">{group.label}</h3>
        <div class="grid grid-cols-3 gap-6">
          {group.items.map((tech) => (
            <div class="flex flex-col items-center gap-2 group">
              <div class="flex items-center justify-center transition-transform duration-200 group-hover:scale-110">
                {tech.icon
                  ? <Icon name={tech.icon} class="w-10 h-10" style={`color: ${tech.color ?? '#ffffff'}`} />
                  : <span class="text-2xl font-bold text-zinc-400">{tech.name[0]}</span>
                }
              </div>
              <span class="text-xs text-zinc-200 text-center leading-tight group-hover:text-white transition-colors duration-200">{tech.name}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
