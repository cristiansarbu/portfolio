---
import '../styles/global.css';
import { Font } from 'astro:assets';
import Nav from '../components/Nav.astro';
import type { useTranslations, Locale } from '../i18n/utils';

interface Props {
  title?: string;
  lang: Locale;
  t: ReturnType<typeof useTranslations>;
}
const { title, lang, t } = Astro.props;

const pageTitle = title ?? t('meta.title');
const description = t('meta.description');
const canonicalUrl = Astro.url.href;
const ogImage = new URL('/og-image.png', Astro.site).href;

const siteBase = (Astro.site?.href ?? '').replace(/\/$/, '');
const hreflangs = [
  { hreflang: 'es',        href: `${siteBase}/`     },
  { hreflang: 'en',        href: `${siteBase}/en/`  },
  { hreflang: 'de',        href: `${siteBase}/de/`  },
  { hreflang: 'x-default', href: `${siteBase}/`     },
];

const ogLocale: Record<Locale, string> = {
  es: 'es_ES',
  en: 'en_US',
  de: 'de_DE',
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${siteBase}/#person`,
  name: 'Angelo Cristian Sarbu',
  alternateName: 'Cristian Sarbu',
  jobTitle: t('hero.role'),
  description,
  url: siteBase || undefined,
  image: ogImage,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Logroño',
    addressRegion: 'La Rioja',
    addressCountry: 'ES',
  },
  knowsLanguage: ['es', 'ro', 'en', 'de'],
  knowsAbout: [
    'AWS', 'Docker', 'Docker Compose', 'Proxmox', 'vLLM', 'Nginx',
    'PHP', 'Laravel', 'Slim', 'Node.js', 'Express', 'PostgreSQL', 'MySQL', 'Java',
    'TypeScript', 'JavaScript', 'Angular', 'Tailwind CSS', 'Astro', 'Bash',
    'Hexagonal Architecture', 'DDD', 'CQRS',
  ],
  alumniOf: {
    '@type': 'EducationalOrganization',
    name: 'C.P.C. Sagrado Corazón Jesuitas',
  },
  worksFor: {
    '@type': 'Organization',
    name: 'Arsys',
  },
  sameAs: [
    'https://www.linkedin.com/in/angelo-cristian-sarbu/',
    'https://github.com/cristiansarbu',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteBase}/#website`,
  url: siteBase || undefined,
  name: 'Angelo Cristian Sarbu',
  inLanguage: lang,
  publisher: { '@id': `${siteBase}/#person` },
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type"         content="website" />
    <meta property="og:url"          content={canonicalUrl} />
    <meta property="og:title"        content={pageTitle} />
    <meta property="og:description"  content={description} />
    <meta property="og:locale"       content={ogLocale[lang]} />
    <meta property="og:site_name"    content="Angelo Cristian Sarbu" />
    <meta property="og:image"        content={ogImage} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"    content="Angelo Cristian Sarbu - Full-Stack Developer" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- hreflang alternates -->
    {hreflangs.map(({ hreflang, href }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Font -->
    <Font cssVariable="--font-onest" preload />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </head>
  <body class="text-zinc-100 antialiased" style="font-family: var(--font-onest), sans-serif;">
    <Nav t={t} lang={lang} />
    <main id="top">
      <slot />
    </main>
  </body>
</html>
