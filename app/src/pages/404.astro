---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, type Locale } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const homePath: Record<Locale, string> = {
  es: '/',
  en: '/en/',
  de: '/de/',
};
---

<Layout lang={lang} t={t} title={`404 - ${t('notfound.title')}`}>
  <section class="min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <p class="text-7xl sm:text-8xl font-bold text-blue-400 mb-4">404</p>
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">{t('notfound.title')}</h1>
    <p class="text-zinc-400 max-w-md mb-8">{t('notfound.message')}</p>
    <a
      href={homePath[lang]}
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-zinc-800 border border-zinc-700 text-zinc-300 text-sm font-medium hover:bg-zinc-700 transition-colors"
    >
      {t('notfound.cta')}
    </a>
  </section>
</Layout>
